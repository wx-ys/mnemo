# =============================================================================
# Mnemo Environment Variables
# =============================================================================
# Copy this file and fill in your API keys:
#   cp .env.example .env
#
# Mnemo auto-loads .env from these locations (later overrides earlier):
#   1. ~/.config/mnemo/.env              (global)
#   2. {data_dir}/.mnemo/.env            (project — created by `mnemo init`)
#   3. ./.env                            (current directory — highest priority)
# =============================================================================

# =============================================================================
# LLM — Wiki generation + entity extraction (OpenAI-compatible /chat/completions)
# =============================================================================
# Mnemo uses OpenAI-compatible protocol. Switch providers via config.toml:
#   [llm]
#   active = "openai"       # the registered provider name
#
#   [llm.openai]
#   model = "deepseek-chat"
#   # api_key / base_url read from LLM_API_KEY / LLM_BASE_URL env vars.
#   # Override by uncommenting and setting a literal value.

# --- DeepSeek (recommended — best value, strong Chinese) ---
LLM_API_KEY=sk-your-deepseek-key
LLM_BASE_URL=https://api.deepseek.com/v1

# --- Aliyun DashScope (Qwen) — great Chinese, fast in China ---
# LLM_API_KEY=sk-your-dashscope-key
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- OpenAI ---
# LLM_API_KEY=sk-your-openai-key
# unset LLM_BASE_URL

# --- Ollama (local, free — `ollama pull qwen2.5` first) ---
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama

# Model is set in config.toml via llm.openai.model:
#   DeepSeek:  deepseek-chat / deepseek-reasoner
#   Aliyun:    qwen-plus / qwen-max / qwen-turbo
#   OpenAI:    gpt-4o / gpt-4o-mini
#   Ollama:    qwen2.5:latest / llama3:latest

# =============================================================================
# Embedding — vector search (OpenAI-compatible /embeddings endpoint)
# =============================================================================
# Switch providers via config.toml:
#   [embedding]
#   active = "openai"       # or "dashscope"
#
#   [embedding.openai]
#   model = "text-embedding-3-small"
#   # api_key / base_url read from EMBED_API_KEY / EMBED_BASE_URL env vars.

# --- OpenAI (default — text-embedding-3-small, 1536-dim) ---
EMBED_API_KEY=sk-your-openai-key
EMBED_BASE_URL=

# --- Aliyun DashScope (text-embedding-v4, 1024-dim) ---
# Switch in config.toml: embedding.active = "dashscope"
# EMBED_API_KEY=sk-your-dashscope-key
# EMBED_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Other compatible providers (set in config.toml):
#   Jina AI:  base_url = "https://api.jina.ai/v1", model = "jina-embeddings-v3"
#   Ollama:   base_url = "http://localhost:11434/v1", model = "bge-m3"

# =============================================================================
# Remote Sync — rclone (optional)
# =============================================================================
# RCLONE_REMOTE=s3://my-bucket/mnemo-backup
